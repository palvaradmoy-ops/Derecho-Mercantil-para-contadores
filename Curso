<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
--gold:#b8964e;--gold-bright:#d4af5a;--gold-light:#e8cc7a;--gold-dark:#8a6d35;
--gold-glow:rgba(184,150,78,.12);--gold-glow2:rgba(184,150,78,.06);
--black:#090807;--dark:#131210;--dark2:#1c1a17;--dark3:#252320;
--cream:#f5f2ec;--cream2:#ece8df;--warm-white:#faf8f4;
--text-dark:#1a1816;--text-body:#3d3a35;--text-muted:#7a7570;--text-light:#a09a92;
--bg:#faf8f4;--bg-alt:#f2efe8;--card:#ffffff;--border:#e5e0d6;--border-light:#ede9e1;
--serif:'Playfair Display',Georgia,'Times New Roman',serif;
--sans:'Source Sans 3','Segoe UI',system-ui,sans-serif;
--max:1080px;--ease:cubic-bezier(.4,0,.2,1);--ease-out:cubic-bezier(0,.7,.3,1);
--shadow-sm:0 1px 2px rgba(0,0,0,.04),0 1px 4px rgba(0,0,0,.03);
--shadow-md:0 4px 12px rgba(0,0,0,.05),0 1px 4px rgba(0,0,0,.03);
--shadow-lg:0 12px 40px rgba(0,0,0,.08),0 4px 12px rgba(0,0,0,.04);
--shadow-gold:0 8px 30px rgba(184,150,78,.15);
}
[data-theme="dark"]{
--bg:#0e0d0b;--bg-alt:#141311;--card:#1a1816;--border:#2a2723;--border-light:#222019;
--text-dark:#ede8df;--text-body:#c4bfb5;--text-muted:#7a7570;--text-light:#5a5550;
--shadow-sm:0 1px 3px rgba(0,0,0,.2);--shadow-md:0 4px 16px rgba(0,0,0,.25);
--shadow-lg:0 12px 40px rgba(0,0,0,.4);--shadow-gold:0 8px 30px rgba(184,150,78,.1);
--gold-glow:rgba(184,150,78,.08);--gold-glow2:rgba(184,150,78,.04);
}
html{scroll-behavior:smooth;scroll-padding-top:110px}
body{font-family:var(--sans);background:var(--bg);color:var(--text-body);line-height:1.7;font-size:16px;-webkit-font-smoothing:antialiased;transition:background .5s var(--ease),color .5s var(--ease);overflow-x:hidden}
body::after{content:'';position:fixed;inset:0;z-index:9999;pointer-events:none;opacity:.022;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E")}
h1,h2,h3,h4{font-family:var(--serif);color:var(--text-dark);font-weight:600;line-height:1.2}
a{color:var(--gold);text-decoration:none;transition:color .3s var(--ease)}
a:hover{color:var(--gold-bright)}
.container{max-width:var(--max);margin:0 auto;padding:0 28px}
.reveal{opacity:0;transform:translateY(32px);transition:opacity .8s var(--ease-out),transform .8s var(--ease-out)}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-delay-1{transition-delay:.1s}.reveal-delay-2{transition-delay:.2s}.reveal-delay-3{transition-delay:.3s}.reveal-delay-4{transition-delay:.4s}.reveal-delay-5{transition-delay:.5s}
section{padding:100px 0;position:relative}
.section-label{font-family:var(--sans);font-size:.65rem;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:14px;font-weight:600;display:inline-flex;align-items:center;gap:12px}
.section-label::before{content:'';width:24px;height:1px;background:var(--gold)}
.section-title{font-size:clamp(1.7rem,4vw,2.5rem);margin-bottom:16px;font-weight:700}
.section-sub{color:var(--text-muted);max-width:580px;font-size:1rem;line-height:1.8}

/* HEADER */
.header{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(250,248,244,.85);backdrop-filter:blur(20px) saturate(1.4);-webkit-backdrop-filter:blur(20px) saturate(1.4);border-bottom:1px solid var(--border-light);transition:all .5s var(--ease)}
[data-theme="dark"] .header{background:rgba(14,13,11,.85)}
.header .container{display:flex;align-items:center;justify-content:space-between;height:68px}
.logo{font-family:var(--serif);font-size:1.05rem;font-weight:700;color:var(--text-dark);letter-spacing:.2px;transition:color .3s}
.logo span{color:var(--gold)}
nav{display:flex;align-items:center;gap:20px}
nav a.nav-link{font-size:.72rem;letter-spacing:1.2px;text-transform:uppercase;color:var(--text-muted);font-weight:500;transition:color .3s;position:relative}
nav a.nav-link::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--gold);transition:width .3s var(--ease)}
nav a.nav-link:hover{color:var(--gold)}
nav a.nav-link:hover::after{width:100%}
.nav-cta{display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:#fff;padding:9px 18px;border-radius:6px;font-size:.7rem;letter-spacing:.8px;text-transform:uppercase;font-weight:600;transition:all .3s var(--ease);box-shadow:0 2px 8px rgba(184,150,78,.2)}
.nav-cta:hover{transform:translateY(-1px);box-shadow:var(--shadow-gold);color:#fff}
.nav-cta svg{width:13px;height:13px}
.theme-toggle{background:none;border:1px solid var(--border);border-radius:50%;width:34px;height:34px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-muted);transition:all .3s var(--ease)}
.theme-toggle:hover{border-color:var(--gold);color:var(--gold)}
.hamburger{display:none;background:none;border:none;cursor:pointer;padding:4px;color:var(--text-dark)}
.hamburger svg{width:22px;height:22px}

/* HERO */
.hero{padding:170px 0 100px;position:relative;overflow:hidden;min-height:100vh;display:flex;align-items:center}
.hero::before{content:'';position:absolute;top:-30%;right:-15%;width:70%;height:130%;background:radial-gradient(ellipse at 60% 40%,var(--gold-glow),transparent 65%);pointer-events:none;animation:heroGlow 8s ease-in-out infinite alternate}
.hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent)}
@keyframes heroGlow{0%{opacity:.6;transform:scale(1)}100%{opacity:1;transform:scale(1.05)}}
.hero-grid{display:grid;grid-template-columns:1fr 340px;gap:60px;align-items:center;position:relative;z-index:1}
.hero-left{max-width:620px}
.hero-edition{display:inline-flex;align-items:center;gap:8px;background:var(--gold-glow);border:1px solid rgba(184,150,78,.15);padding:6px 16px;border-radius:100px;font-size:.72rem;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);margin-bottom:28px;animation:fadeInUp .8s var(--ease-out) both}
.hero-edition .dot{width:6px;height:6px;border-radius:50%;background:var(--gold);animation:pulse 2s ease infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.hero h1{font-size:clamp(2.2rem,5.5vw,3.6rem);font-weight:800;line-height:1.1;margin-bottom:24px;animation:fadeInUp .8s var(--ease-out) .1s both}
.hero h1 em{font-style:italic;font-weight:500;background:linear-gradient(135deg,var(--gold),var(--gold-bright));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-sub{font-size:1.05rem;color:var(--text-muted);line-height:1.85;margin-bottom:36px;animation:fadeInUp .8s var(--ease-out) .2s both}
.hero-badges{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:36px;animation:fadeInUp .8s var(--ease-out) .3s both}
.badge{display:inline-flex;align-items:center;gap:5px;background:var(--card);border:1px solid var(--border);padding:7px 14px;border-radius:100px;font-size:.75rem;font-weight:500;color:var(--text-body);letter-spacing:.2px;transition:all .3s var(--ease);box-shadow:var(--shadow-sm)}
.badge:hover{border-color:var(--gold);transform:translateY(-1px)}
.badge svg{width:13px;height:13px;color:var(--gold);flex-shrink:0}
.hero-ctas{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:20px;animation:fadeInUp .8s var(--ease-out) .4s both}
.btn{display:inline-flex;align-items:center;gap:8px;padding:15px 30px;border-radius:8px;font-size:.88rem;font-weight:600;letter-spacing:.3px;cursor:pointer;transition:all .35s var(--ease);border:none;text-align:center;position:relative;overflow:hidden}
.btn-primary{background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:#fff;box-shadow:0 4px 16px rgba(184,150,78,.25)}
.btn-primary::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--gold-bright),var(--gold));opacity:0;transition:opacity .35s}
.btn-primary:hover{transform:translateY(-2px);box-shadow:var(--shadow-gold);color:#fff}
.btn-primary:hover::before{opacity:1}
.btn-primary span{position:relative;z-index:1;display:flex;align-items:center;gap:8px}
.btn-secondary{background:var(--card);color:var(--text-body);border:1px solid var(--border);box-shadow:var(--shadow-sm)}
.btn-secondary:hover{border-color:var(--gold);color:var(--gold);transform:translateY(-1px)}
.btn svg{width:16px;height:16px}
.hero-micro{font-size:.82rem;color:var(--text-muted);line-height:1.6;animation:fadeInUp .8s var(--ease-out) .5s both}
.hero-micro strong{color:var(--gold);font-weight:600}
@keyframes fadeInUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.hero-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:32px 28px;box-shadow:var(--shadow-lg);position:relative;animation:fadeInUp .8s var(--ease-out) .4s both}
.hero-card::before{content:'';position:absolute;top:-1px;left:24px;right:24px;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent);border-radius:2px}
.hero-card-row{display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid var(--border-light)}
.hero-card-row:last-child{border:none}
.hero-card-label{font-size:.7rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--text-muted);font-weight:600}
.hero-card-value{font-family:var(--serif);font-size:1rem;font-weight:600;color:var(--text-dark);text-align:right}
.hero-card-value.gold{color:var(--gold)}
.hero-card-cta{display:block;text-align:center;margin-top:20px;padding:13px;border-radius:8px;background:linear-gradient(135deg,var(--gold),var(--gold-dark));color:#fff;font-size:.82rem;font-weight:600;letter-spacing:.5px;text-transform:uppercase;transition:all .35s var(--ease);box-shadow:0 4px 16px rgba(184,150,78,.2)}
.hero-card-cta:hover{transform:translateY(-1px);box-shadow:var(--shadow-gold);color:#fff}

/* PROBLEM */
.problem-section{padding:80px 0;position:relative;background:var(--dark);color:#fff;overflow:hidden}
[data-theme="dark"] .problem-section{background:#080705}
.problem-section::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 20% 50%,rgba(184,150,78,.06),transparent 60%);pointer-events:none}
.problem-inner{position:relative;z-index:1;max-width:700px;margin:0 auto;text-align:center}
.problem-inner .section-label::before{background:var(--gold)}
.problem-inner blockquote{font-family:var(--serif);font-size:clamp(1.1rem,2.5vw,1.4rem);font-style:italic;line-height:1.8;color:rgba(255,255,255,.85);margin:24px 0;position:relative;padding:0 20px}
.problem-inner blockquote::before,.problem-inner blockquote::after{font-family:var(--serif);font-size:3rem;color:var(--gold);position:absolute;opacity:.4}
.problem-inner blockquote::before{content:'\201C';top:-10px;left:-8px}
.problem-inner blockquote::after{content:'\201D';bottom:-30px;right:-8px}
.problem-inner .attribution{font-family:var(--sans);font-style:normal;font-size:.88rem;color:var(--gold);font-weight:600;margin-top:20px}

/* AUDIENCE */
.audience-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;margin-top:40px}
.audience-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:28px 24px;display:flex;align-items:flex-start;gap:16px;transition:all .35s var(--ease);box-shadow:var(--shadow-sm)}
.audience-card:hover{border-color:rgba(184,150,78,.3);transform:translateY(-3px);box-shadow:var(--shadow-md)}
.audience-icon{width:42px;height:42px;border-radius:10px;background:var(--gold-glow);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.audience-icon svg{width:20px;height:20px;color:var(--gold)}
.audience-card h4{font-size:.95rem;margin-bottom:4px;font-weight:600}
.audience-card p{font-size:.85rem;color:var(--text-muted);line-height:1.6}

/* BENEFITS */
.benefits-section{background:var(--bg-alt)}
.benefits-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:44px}
.benefit-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:32px 26px;transition:all .4s var(--ease);box-shadow:var(--shadow-sm);position:relative;overflow:hidden}
.benefit-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),transparent);opacity:0;transition:opacity .4s}
.benefit-card:hover{border-color:rgba(184,150,78,.25);transform:translateY(-4px);box-shadow:var(--shadow-lg)}
.benefit-card:hover::before{opacity:1}
.benefit-num{font-family:var(--serif);font-size:2.4rem;font-weight:800;line-height:1;margin-bottom:16px;background:linear-gradient(180deg,rgba(184,150,78,.15),transparent);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.benefit-card h3{font-size:1.05rem;margin-bottom:8px;line-height:1.3}
.benefit-card p{font-size:.88rem;color:var(--text-muted);line-height:1.65}

/* INCLUDES */
.includes-strip{display:flex;gap:0;margin-top:44px;border:1px solid var(--border);border-radius:14px;overflow:hidden;background:var(--card);box-shadow:var(--shadow-sm)}
.include-item{flex:1;padding:28px 20px;text-align:center;border-right:1px solid var(--border-light);transition:all .3s var(--ease)}
.include-item:last-child{border-right:none}
.include-item:hover{background:var(--gold-glow2)}
.include-item svg{width:28px;height:28px;color:var(--gold);margin:0 auto 12px;display:block}
.include-item .inc-title{font-family:var(--serif);font-weight:600;font-size:.92rem;display:block;margin-bottom:4px;color:var(--text-dark)}
.include-item .inc-desc{font-size:.78rem;color:var(--text-muted);line-height:1.5}

/* PROGRAM */
.program-section{background:var(--bg-alt)}
.session-card{background:var(--card);border:1px solid var(--border);border-radius:14px;margin-bottom:16px;overflow:hidden;box-shadow:var(--shadow-sm);transition:all .35s var(--ease)}
.session-card:hover{box-shadow:var(--shadow-md)}
.session-head{padding:24px 28px;cursor:pointer;display:flex;align-items:center;gap:20px;transition:background .3s}
.session-head:hover{background:var(--gold-glow2)}
.session-number{width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,var(--gold),var(--gold-dark));display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-size:1.1rem;font-weight:800;color:#fff;flex-shrink:0}
.session-meta{flex:1}
.session-date{font-size:.7rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:2px}
.session-title{font-family:var(--serif);font-size:1.1rem;font-weight:600;color:var(--text-dark)}
.session-toggle{width:28px;height:28px;border-radius:50%;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;transition:all .3s;flex-shrink:0}
.session-toggle svg{width:14px;height:14px;color:var(--text-muted);transition:transform .3s var(--ease)}
.session-card.active .session-toggle{border-color:var(--gold);background:var(--gold-glow)}
.session-card.active .session-toggle svg{transform:rotate(45deg);color:var(--gold)}
.session-body{display:none;padding:0 28px 24px 92px}
.session-card.active .session-body{display:block}
.session-body ul{list-style:none}
.session-body ul li{position:relative;padding-left:20px;font-size:.9rem;color:var(--text-muted);line-height:1.7;margin-bottom:5px}
.session-body ul li::before{content:'';position:absolute;left:0;top:11px;width:8px;height:1px;background:var(--gold)}
.errors-box{background:var(--card);border:1px solid var(--border);border-left:3px solid var(--gold);border-radius:0 14px 14px 0;padding:28px 32px;margin-top:32px;box-shadow:var(--shadow-sm)}
.errors-box h4{font-size:.95rem;margin-bottom:12px;color:var(--gold);font-family:var(--sans);font-weight:600;letter-spacing:.5px}
.errors-box ul{list-style:none}
.errors-box ul li{font-size:.88rem;color:var(--text-muted);padding:4px 0 4px 22px;position:relative}
.errors-box ul li::before{content:'\2715';position:absolute;left:0;color:var(--gold);font-size:.75rem;font-weight:700;top:5px}

/* METHODOLOGY */
.method-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:44px}
.method-item{text-align:center;padding:32px 20px;border:1px solid var(--border);border-radius:14px;background:var(--card);transition:all .35s var(--ease);box-shadow:var(--shadow-sm);position:relative;overflow:hidden}
.method-item::after{content:'';position:absolute;bottom:0;left:20%;right:20%;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:0;transition:opacity .4s}
.method-item:hover{transform:translateY(-3px);box-shadow:var(--shadow-md)}
.method-item:hover::after{opacity:1}
.method-item svg{width:32px;height:32px;color:var(--gold);margin:0 auto 14px}
.method-item h4{font-size:.92rem;margin-bottom:6px}
.method-item p{font-size:.8rem;color:var(--text-muted);line-height:1.5}

/* FICHA */
.ficha-section{background:var(--bg-alt)}
.ficha{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:16px;overflow:hidden;margin-top:40px;box-shadow:var(--shadow-sm)}
.ficha-item{background:var(--card);padding:28px 24px;transition:background .3s}
.ficha-item:hover{background:var(--gold-glow2)}
.ficha-item .fi-label{font-size:.65rem;text-transform:uppercase;letter-spacing:2px;color:var(--text-muted);margin-bottom:8px;font-weight:600}
.ficha-item .fi-value{font-family:var(--serif);font-size:1.05rem;font-weight:600;color:var(--text-dark)}

/* INSTRUCTOR */
.instructor-section{position:relative;overflow:hidden}
.instructor-section::before{content:'';position:absolute;bottom:-20%;right:-10%;width:50%;height:80%;background:radial-gradient(ellipse,var(--gold-glow2),transparent 65%);pointer-events:none}
.instructor-card{display:grid;grid-template-columns:200px 1fr;gap:40px;align-items:start;margin-top:40px;padding:44px;border:1px solid var(--border);border-radius:18px;background:var(--card);box-shadow:var(--shadow-md);position:relative;z-index:1}
.instructor-card::before{content:'';position:absolute;top:-1px;left:40px;right:40px;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent);border-radius:2px}
.instructor-visual{text-align:center}
.instructor-photo{width:160px;height:160px;border-radius:50%;margin:0 auto 16px;border:3px solid var(--gold);box-shadow:0 8px 32px rgba(0,0,0,.15);object-fit:cover;transition:all .5s var(--ease)}
.instructor-photo:hover{transform:scale(1.04);box-shadow:0 12px 40px rgba(184,150,78,.25)}
.instructor-name-small{font-size:.78rem;color:var(--text-muted);letter-spacing:.5px}
.instructor-info h3{font-size:1.5rem;margin-bottom:16px;font-weight:700}
.instructor-info p{font-size:.92rem;color:var(--text-muted);line-height:1.8;margin-bottom:20px}
.instructor-tags{display:flex;gap:10px;flex-wrap:wrap}
.instructor-tags span{font-size:.76rem;padding:6px 16px;border:1px solid var(--border);border-radius:100px;color:var(--text-muted);font-weight:500;letter-spacing:.3px;transition:all .3s}
.instructor-tags span:hover{border-color:var(--gold);color:var(--gold)}

/* PRICING */
.pricing-section{background:var(--dark);color:#fff;overflow:hidden;position:relative}
